# ==========================================
# APP
# ==========================================
# Konfigurasi dasar aplikasi FastAPI

APP_ENV=development
# Format: development | staging | production
# Deskripsi: Environment aplikasi untuk logging level, error handling, CORS
# Status: WAJIB
# Default: development

APP_VERSION=1.0.0
# Format: semantic versioning (e.g., 1.0.0)
# Deskripsi: Versi aplikasi untuk API response headers
# Status: OPSIONAL
# Catatan: Biasanya diambil dari pyproject.toml

SECRET_KEY=your-secret-key-min-32-chars-change-in-production-f8k9x2q
# Format: String random alphanumeric minimal 32 karakter
# Deskripsi: Secret key untuk JWT signing, session encryption
# Status: WAJIB
# Cara mendapatkan: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Catatan: JANGAN gunakan placeholder ini di production

API_KEY=your-api-key-min-32-chars-secure-change-in-production
# Format: String random alphanumeric minimal 32 karakter
# Deskripsi: API key untuk external service authentication (client headers)
# Status: WAJIB
# Cara mendapatkan: Generate random string, share ke frontend team
# Catatan: Client harus kirim ini di header "X-API-Key"

# ==========================================
# AMD / vLLM
# ==========================================
# Konfigurasi vLLM inference server (Llama-3-70B di AMD MI300X)
# Dokumentasi: https://docs.vllm.ai/

VLLM_HOST=localhost
# Format: IP address atau hostname
# Deskripsi: Host vLLM inference server
# Status: WAJIB
# Default (dev): localhost
# Default (prod): internal-vllm.amd-cloud.internal

VLLM_PORT=8000
# Format: integer port number
# Deskripsi: Port vLLM inference server
# Status: WAJIB
# Default: 8000

VLLM_MODEL_NAME=meta-llama/Llama-3-70b-instruct
# Format: model identifier dari Hugging Face
# Deskripsi: Model name untuk vLLM inference
# Status: WAJIB
# Catatan: Harus sudah di-download & di-cache di AMD MI300X

VLLM_MAX_TOKENS=2048
# Format: integer
# Deskripsi: Maximum output token length untuk inference
# Status: OPSIONAL
# Default: 2048
# Catatan: Lebih tinggi = lebih lama inference time

VLLM_TEMPERATURE=0.1
# Format: float 0.0-2.0
# Deskripsi: Sampling temperature untuk model output (deterministik vs kreatif)
# Status: OPSIONAL
# Default: 0.1
# Catatan: 0.1 = sangat deterministik (konsisten), bagus untuk fallacy detection

VLLM_TOP_P=0.95
# Format: float 0.0-1.0
# Deskripsi: Nucleus sampling parameter
# Status: OPSIONAL
# Default: 0.95

# ==========================================
# WHISPER
# ==========================================
# Konfigurasi Whisper service untuk audio transcription
# Dokumentasi: https://openai.com/research/whisper

WHISPER_HOST=localhost
# Format: IP address atau hostname
# Deskripsi: Host Whisper inference server
# Status: OPSIONAL (hanya jika ada audio input feature)
# Default (dev): localhost

WHISPER_PORT=8001
# Format: integer port number
# Deskripsi: Port Whisper service
# Status: OPSIONAL
# Default: 8001

WHISPER_MODEL=large-v3
# Format: large-v3 | medium | base | small | tiny
# Deskripsi: Whisper model size (trade-off accuracy vs speed)
# Status: OPSIONAL
# Default: large-v3
# Catatan: large-v3 = paling akurat, paling lambat

# ==========================================
# QDRANT
# ==========================================
# Konfigurasi Qdrant vector database untuk semantic search fallacy patterns
# Dokumentasi: https://qdrant.tech/

QDRANT_HOST=localhost
# Format: IP address, hostname, atau URL
# Deskripsi: Host Qdrant vector database
# Status: WAJIB
# Default (dev): localhost
# Default (prod): qdrant.internal.amd-cloud.internal

QDRANT_PORT=6333
# Format: integer port number
# Deskripsi: Port Qdrant HTTP API
# Status: WAJIB
# Default: 6333
# Catatan: GRPC port biasanya port+1 (6334)

QDRANT_API_KEY=
# Format: String token
# Deskripsi: API key untuk Qdrant authentication
# Status: OPSIONAL (jika Qdrant punya authentication)
# Catatan: Kosongkan jika Qdrant berjalan di localhost tanpa auth

QDRANT_COLLECTION_NAME=fallacy_vectors
# Format: String lowercase alphanumeric with underscore
# Deskripsi: Nama collection untuk vector embeddings fallacy patterns
# Status: WAJIB
# Catatan: Collection akan auto-created jika tidak ada (dari seeding script)

# ==========================================
# SUPABASE
# ==========================================
# Database & Auth backend (shared dengan frontend)
# Dapatkan dari: https://app.supabase.com → Settings → API

SUPABASE_URL=https://bfhjknbboxhsxbwnmjov.supabase.co
# Format: https://[project-id].supabase.co
# Deskripsi: URL endpoint Supabase project (shared dengan Revonalar)
# Status: WAJIB

SUPABASE_SERVICE_ROLE_KEY=
# Deskripsi: Service role key untuk backend operations (full access)
# Format: JWT token panjang
# Status: WAJIB
# Catatan: JANGAN expose ke frontend, hanya server-side
# Cara mendapatkan: Supabase Dashboard → Settings → API → Service Role Key

# ==========================================
# REDIS
# ==========================================
# Cache & rate limiting (optional tapi recommended untuk production)

REDIS_URL=redis://localhost:6379
# Format: redis://[user:password@]host:port[/db]
# Deskripsi: Redis connection string untuk caching & rate limiting
# Status: OPSIONAL (ada in-memory fallback)
# Example: redis://default:mypass@redis.amd-cloud.internal:6379/0
# Catatan: Untuk development bisa skip, akan pakai in-memory cache

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# API keys untuk external services

YOUTUBE_API_KEY=
# Format: Google API key
# Deskripsi: YouTube Data API key untuk fetch video transcript & metadata
# Status: WAJIB (untuk YouTube feature)
# Cara mendapatkan: https://console.cloud.google.com → Create project → YouTube Data API v3
# Catatan: Needs quota: 100 units/day minimum

JINA_API_KEY=
# Format: API key dari Jina
# Deskripsi: Jina Reader API key untuk web scraping & article parsing
# Status: WAJIB (untuk URL feature)
# Cara mendapatkan: https://jina.ai → Dashboard → API keys
# Catatan: Alternative ke paid services, memiliki free tier

SENTRY_DSN=
# Format: https://[key]@[host]/[project-id]
# Deskripsi: Sentry DSN untuk error tracking & monitoring
# Status: OPSIONAL (untuk production monitoring)
# Cara mendapatkan: https://sentry.io → Create project → Python
# Catatan: Kosongkan untuk development

# ==========================================
# RATE LIMITING
# ==========================================
# Konfigurasi rate limiting per user/IP

RATE_LIMIT_PER_MINUTE=10
# Format: integer
# Deskripsi: Maximum requests per minute per IP address
# Status: OPSIONAL
# Default: 10
# Catatan: Untuk free tier users

RATE_LIMIT_DAILY_FREE=5
# Format: integer
# Deskripsi: Maximum analyses per hari untuk free tier users
# Status: OPSIONAL
# Default: 5
# Catatan: Enforcement via Supabase auth_type = 'free'

RATE_LIMIT_DAILY_PREMIUM=100
# Format: integer
# Deskripsi: Maximum analyses per hari untuk premium tier users
# Status: OPSIONAL
# Default: 100
# Catatan: Enforcement via Supabase auth_type = 'premium'

# ==========================================
# LOGGING
# ==========================================
# Konfigurasi logging level

LOG_LEVEL=INFO
# Format: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Deskripsi: Logging verbosity level
# Status: OPSIONAL
# Default: INFO (dev), WARNING (prod)
# Catatan: DEBUG untuk troubleshooting, WARNING untuk production

# ==========================================
# CORS
# ==========================================
# Cross-Origin Resource Sharing

CORS_ORIGINS=http://localhost:5173,https://fallacyx.revonalar.io
# Format: Comma-separated list of URLs
# Deskripsi: Allowed origins untuk CORS requests
# Status: OPSIONAL
# Default: * (di development)
# Catatan: Di production, list explicitly allowed domains saja
