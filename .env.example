# ==========================================
# SUPABASE
# ==========================================
# Database & Auth backend untuk user management, history, leaderboard
# Dapatkan dari: https://app.supabase.com → Settings → API

PUBLIC_SUPABASE_URL=https://bfhjknbboxhsxbwnmjov.supabase.co
# Format: https://[project-id].supabase.co
# Deskripsi: URL endpoint Supabase project Anda (shared dengan Revonalar, Singapore region)
# Status: WAJIB

PUBLIC_SUPABASE_ANON_KEY=
# Deskripsi: Public anon key untuk client-side requests
# Format: JWT token panjang
# Status: WAJIB
# Catatan: Ini adalah public key, aman di expose ke frontend

SUPABASE_SERVICE_ROLE_KEY=
# Deskripsi: Service role key untuk server-side operations
# Format: JWT token panjang, lebih powerful dari anon key
# Status: WAJIB
# Catatan: JANGAN expose ke frontend, hanya di server side

# ==========================================
# BACKEND API (AMD Developer Cloud)
# ==========================================
# Endpoint FastAPI backend yang berjalan di AMD Developer Cloud
# Dapatkan dari: Admin panel atau dokumentasi deployment

PRIVATE_API_URL=http://localhost:8000
# Format: http://[host]:[port] atau https://[domain]
# Deskripsi: URL backend API untuk server-to-server requests (dalam private network)
# Status: WAJIB
# Catatan: Untuk production gunakan URL internal/private, bukan public

VITE_AMD_BACKEND_URL=http://localhost:8000
# Format: http://[host]:[port] atau https://[domain]
# Deskripsi: URL backend FastAPI di AMD Developer Cloud, dipakai oleh proxy /api/analyze (server-side)
# Status: WAJIB

PRIVATE_API_KEY=your-api-key-here-min-32-chars-secure
# Format: String alphanumeric minimal 32 karakter
# Deskripsi: API key untuk authenticated requests ke backend
# Status: WAJIB
# Cara mendapatkan: Generate di backend app/core/security.py atau admin panel

PUBLIC_API_URL_CLIENT=https://api.fallacyx.dev
# Format: https://[domain] atau http://[host]:[port]
# Deskripsi: URL backend API yang bisa diakses dari client browser (public)
# Status: WAJIB
# Catatan: Bisa sama atau berbeda dari PRIVATE_API_URL tergantung networking

# ==========================================
# CLOUDFLARE
# ==========================================
# Konfigurasi Cloudflare Pages untuk deployment frontend
# Dapatkan dari: https://dash.cloudflare.com → Account Settings

CF_ACCOUNT_ID=
# Format: String alphanumeric 32 karakter
# Deskripsi: Cloudflare Account ID untuk deployment
# Status: OPSIONAL (hanya untuk deployment otomatis)
# Cara mendapatkan: Cloudflare Dashboard → Account Settings

CF_API_TOKEN=
# Format: String token Cloudflare
# Deskripsi: API token untuk deploy ke Cloudflare Pages
# Status: OPSIONAL (hanya untuk deployment otomatis)
# Catatan: Perlu permission: Account.Workers Routes:Edit, Pages:Edit

# ==========================================
# APP CONFIG
# ==========================================
# Konfigurasi umum aplikasi

PUBLIC_APP_URL=http://localhost:5173
# Format: http://[domain] atau https://[domain]
# Deskripsi: Public URL aplikasi frontend (untuk meta tags, share links, email)
# Status: WAJIB
# Catatan: Di production gunakan domain resmi (e.g., https://fallacyx.revonalar.io)

PUBLIC_APP_NAME=FallacyChecker
# Format: String nama aplikasi
# Deskripsi: Nama aplikasi untuk UI, meta tags, dokumentasi
# Status: OPSIONAL (ada default value)

PUBLIC_BRAND_NAME=Revonalar
# Format: String nama brand
# Deskripsi: Nama brand induk di meta tags
# Status: OPSIONAL

PUBLIC_ENVIRONMENT=development
# Format: development | staging | production
# Deskripsi: Environment flag untuk feature flags, logging level
# Status: WAJIB
